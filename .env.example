# ============================================================
# New Euro Consultants — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# ── Database (required) ──────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/neweuro

# ── Auth (required) ──────────────────────────────────────────
# Generate with: openssl rand -base64 32
SESSION_SECRET=replace-with-openssl-rand-base64-32

# ── Admin seed credentials ───────────────────────────────────
ADMIN_EMAIL=admin@neweuroconsultants.com
ADMIN_PASSWORD=ChangeMe!StrongPass2026

# ── API server port ──────────────────────────────────────────
PORT=5000

# ── Storage ──────────────────────────────────────────────────
# 'local' writes to ./public/uploads (dev)
# 's3' uses Cloudflare R2 or AWS S3 (production)
STORAGE_DRIVER=local
UPLOAD_DIR=./public/uploads

# If STORAGE_DRIVER=s3 (Cloudflare R2 example):
# S3_ENDPOINT=https://<acct>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET=neweuro-media
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_PUBLIC_URL=https://media.neweuroconsultants.com

# ── Email (Resend) ───────────────────────────────────────────
# Without these, email silently no-ops (safe for local dev).
RESEND_API_KEY=
EMAIL_FROM=noreply@neweuroconsultants.com
EMAIL_TO_ADMIN=info@neweuroconsultants.com

# ── WhatsApp / Contact ───────────────────────────────────────
WHATSAPP_NUMBER=923145352222
PHONE_NUMBER=+923145352222

# ── Frontend Vite (required when running frontend directly) ──
# These are set automatically by the Replit artifact workflow.
# Set them manually for local dev:
# PORT=5173
# BASE_PATH=/

# ── API proxy (frontend dev) ─────────────────────────────────
# Vite proxies /api/* to this target during development.
API_PROXY_TARGET=http://localhost:5000

# ── Analytics (optional) ─────────────────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_FB_PIXEL=
